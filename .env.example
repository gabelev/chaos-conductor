# Chaos Conductor configuration. All optional — copy to .env and edit as needed.
# The Conductor runs on the same box as claude-rc-server and drives it locally.

# Path to your claude-rc-server checkout (its scripts/ are what we shell out to).
# Default: ~/claude-rc-server
# CLAUDE_RC_ROOT=/home/youruser/claude-rc-server

# Where repos are cloned (mirror claude-rc-server's PROJECTS_DIR). Default ~/projects.
# PROJECTS_DIR=/home/youruser/projects

# Pinned tmux socket name claude-rc-server uses (-L). Default: claude-rc
# CLAUDE_RC_TMUX_SOCKET=claude-rc

# Dry run: log intended commands instead of executing them. Lets you exercise
# the whole surface off a droplet. Set to 1/true to enable.
# CONDUCTOR_DRY_RUN=0

# Per-command timeout in ms (default 120000).
# CONDUCTOR_EXEC_TIMEOUT_MS=120000

# Silence the "couldn't confirm a Chaos Dimension MCP token" status warning once
# you've verified the token is wired into claude-rc-server's env file.
# CONDUCTOR_ASSUME_TOKEN=0
